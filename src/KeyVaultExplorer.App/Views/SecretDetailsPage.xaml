<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KeyVaultExplorer.App.Views.SecretDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:KeyVaultExplorer.App.ViewModels"
    x:DataType="viewModels:SecretDetailsViewModel"
    Title="Secret Details">

    <ScrollView>
        <Grid
            Padding="24"
            RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
            RowSpacing="16">

            <VerticalStackLayout Grid.Row="0" Spacing="4">
                <Label
                    FontSize="28"
                    SemanticProperties.HeadingLevel="Level1"
                    Text="{Binding HeaderTitle}" />
                <Label
                    Text="{Binding VaultSubtitle}"
                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
            </VerticalStackLayout>

            <Border Grid.Row="1" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="{Binding StatusMessage}"
                        IsVisible="{Binding HasStatus}" />
                    <Label
                        Text="{Binding ErrorMessage}"
                        IsVisible="{Binding HasError}"
                        TextColor="{StaticResource Magenta}" />
                </VerticalStackLayout>
            </Border>

            <Grid
                Grid.Row="2"
                ColumnDefinitions="*,Auto"
                ColumnSpacing="12">
                <Picker
                    Grid.Column="0"
                    Title="Select secret version"
                    ItemsSource="{Binding Versions}"
                    ItemDisplayBinding="{Binding Version}"
                    SelectedItem="{Binding SelectedVersion, Mode=TwoWay}" />
                <Button
                    Grid.Column="1"
                    Command="{Binding RefreshCommand}"
                    Text="Refresh" />
            </Grid>

            <Grid
                Grid.Row="3"
                ColumnDefinitions="*,*"
                ColumnSpacing="12">
                <Border Grid.Column="0" Padding="16">
                    <VerticalStackLayout Spacing="6">
                        <Label FontAttributes="Bold" Text="Updated" />
                        <Label Text="{Binding UpdatedOnText}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" Padding="16">
                    <VerticalStackLayout Spacing="6">
                        <Label FontAttributes="Bold" Text="Enabled" />
                        <Label Text="{Binding IsSecretEnabled}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border Grid.Row="4" Padding="16">
                <VerticalStackLayout Spacing="6">
                    <Label FontAttributes="Bold" Text="Content Type" />
                    <Label Text="{Binding ContentType}" />
                </VerticalStackLayout>
            </Border>

            <Border Grid.Row="5" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <HorizontalStackLayout HorizontalOptions="Fill" Spacing="12">
                        <Label
                            FontAttributes="Bold"
                            HorizontalOptions="StartAndExpand"
                            Text="Secret Value" />
                        <Button
                            Command="{Binding CopyValueCommand}"
                            IsEnabled="{Binding CanCopyValue}"
                            Text="Copy" />
                    </HorizontalStackLayout>
                    <Editor
                        AutoSize="TextChanges"
                        IsReadOnly="True"
                        MinimumHeightRequest="220"
                        Text="{Binding SecretValue}" />
                </VerticalStackLayout>
            </Border>

            <Border Grid.Row="6" Padding="16">
                <VerticalStackLayout Spacing="6">
                    <Label FontAttributes="Bold" Text="Tags" />
                    <Label Text="{Binding TagsText}" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
